{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "module": "NodeNext",
        "rootDir": "src",
        "outDir": "build/esm",
        "paths": {
            "@/*": ["./src/*"]
        },
        "types": ["@iobroker/types-dev", "@types/node", "@types/mocha", "@types/sinon"]
    },
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "build/**",
        "node_modules/**"
    ]
}
